{
	"name": "@vegardx/pi-ext-nitpick",
	"version": "0.0.0-development",
	"description": "pi.dev extension: long-lived reviewer subagent that watches every edit and feeds simplification opportunities back to the main agent",
	"keywords": ["pi-package", "pi-extension", "code-review", "simplify"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vegardx/pi-ext-nitpick.git"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"pi": {
		"extensions": ["./index.ts"]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@mariozechner/pi-coding-agent": "^0.70.0",
		"@sinclair/typebox": "^0.34.49",
		"semantic-release": "^25.0.1",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/release-notes-generator": "^14.0.3",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/github": "^12.0.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"check": "npm run lint && npm run typecheck && npm run test"
	}
}
